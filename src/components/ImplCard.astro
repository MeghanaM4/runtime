---
interface Props {
  id: string;
  color: string;
  typeLabel: string;
  class?: string;
}

const { id, color, typeLabel, class: className } = Astro.props;
---

<div class:list={["impl-card", className]} id={id}>
  <div class="card-header">
    <span class="card-tag bebas" style={`background: ${color}`}>{typeLabel}</span>
    <span class="card-title bebas" id={`${id}-label`}></span>
  </div>
  <div class="card-body">
    <div class="impl-components">
      <span class="impl-tag bebas">POSSIBLE COMPONENTS</span>
      <div class="impl-chips" id={`${id}-chips`}></div>
    </div>
    <div class="impl-text" id={`${id}-text`}></div>
  </div>
</div>

<style>
  .impl-card {
    background: white;
    border: 3px solid var(--ink);
    border-radius: 16px;
    box-shadow: 5px 5px 0 var(--ink);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(16px);
    pointer-events: none;
    transition:
      opacity 0.4s ease,
      transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .impl-card.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .card-header {
    padding: 14px 16px 12px;
    border-bottom: 2px dashed rgba(0, 0, 0, 0.15);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
    flex-shrink: 0;
  }

  .card-tag {
    font-family: "Space Mono", monospace;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    padding: 3px 10px;
    border-radius: 999px;
    border: 2px solid var(--ink);
    color: var(--ink);
  }

  .card-title {
    font-size: 1.3rem;
    letter-spacing: 0.06em;
  }

  .card-body {
    padding: 14px 16px 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }

  .impl-tag {
    font-family: "Space Mono", monospace;
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    opacity: 0.55;
    display: block;
    margin-bottom: 4px;
  }

  .impl-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .impl-text {
    font-size: 0.75rem;
    line-height: 1.6;
    border-top: 2px dashed rgba(0, 0, 0, 0.15);
    padding-top: 10px;
    margin-top: 2px;
    color: var(--ink);
  }
</style>