---
import Layout from "../layouts/Layout.astro";

const events = [
  {
    type: "WORKSHOP",
    color: "var(--yellow)",
    title: "PCB DESIGN BASICS",
    date: "SUN APR 19",
    time: "2:00 PM – 5:00 PM",
    desc: "PCB basics in KiCAD. We'll be following the Runtime guide.",
  },
  {
    type: "WORKSHOP",
    color: "var(--yellow)",
    title: "HARWARE HELP/LOCK-IN CALL",
    date: "THU APR 23",
    time: "6:00 PM – 7:00 PM",
    desc: "Drop in with any questions about your Runtime board, or just come hang out.",
  },
  {
    type: "COMMUNITY EVENT",
    color: "var(--teal)",
    title: "RUNTIME MINI-GAME",
    date: "TUE APR 21",
    time: "7:00 PM – 8:00 PM",
    desc: "Get paired up with a random Runtime participant and compete to build a board faster than the other teams! Winner gets an exclusive Runtime sticker.",
  },
  {
    type: "WORKSHOP",
    color: "var(--yellow)",
    title: "RUNTIME SPEEDRUN",
    date: "SUN APR 26",
    time: "10:00 AM – 1:00 PM",
    desc: "Speedrunning a Runtime board as fast as possible! Drop in with questions about your board.",
  },

  {
    type: "COMMUNITY EVENT",
    color: "var(--pink)",
    title: "ATHENA RUNTIME WORKSHOP",
    date: "FRI MAY 1",
    time: "6:00 PM – 7:00 PM",
    desc: "Learn how to make a PCB for Runtime! No hardware experience required at all, we'll teach you. Athena (gender minorities) only!",
  },
  {
    type: "WORKSHOP",
    color: "var(--yellow)",
    title: "HARWARE HELP/LOCK-IN CALL",
    date: "SUN MAY 3",
    time: "2:00 PM – 5:00 PM",
    desc: "Drop in with any questions about your Runtime board, or just come hang out.",
  },
];
---

<Layout title="Calendar">
  <main class="calendar-page">
    <nav class="nav-bar">
      <a href="/dashboard" class="nav-back bebas">← BACK</a>
      <span class="nav-title bebas">RUNTIME</span>
    </nav>

    <section class="calendar-header">
      <div class="header-card">
        <h1 class="header-title bebas">WORKSHOPS & HELP CALLS</h1>
      </div>
    </section>

    <section class="events-section">
      <div class="events-grid">
        {
          events.map((event, i) => (
            <div class="event-card" style={`animation-delay: ${i * 80}ms`}>
              <div class="event-header" style={`background: ${event.color}`}>
                <span class="event-type bebas">{event.type}</span>
                <span class="event-date bebas">{event.date}</span>
              </div>
              <div class="event-body">
                <h2 class="event-title bebas">{event.title}</h2>
                <div class="event-meta">
                  <span class="meta-chip bebas">{event.time}</span>
                </div>
                <p class="event-desc">{event.desc}</p>
                <a href="#" class="event-rsvp bebas">
                  RSVP →
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</Layout>

<style>
  .calendar-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  /* ── Nav ── */
  .nav-bar {
    background: var(--ink);
    color: var(--bg);
    display: flex;
    align-items: center;
    padding: 10px 24px;
    gap: 16px;
    flex-shrink: 0;
  }
  .nav-back {
    color: var(--yellow);
    text-decoration: none;
    font-size: 1.1rem;
    letter-spacing: 0.06em;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }
  .nav-back:hover {
    opacity: 0.7;
  }
  .nav-title {
    font-size: 1rem;
    letter-spacing: 0.08em;
    flex: 1;
    text-align: center;
  }

  /* ── Page header ── */
  .calendar-header {
    display: flex;
    justify-content: center;
    padding: 3rem 2rem 1.5rem;
  }

  .header-card {
    background: var(--ink);
    color: var(--bg);
    border: 4px solid var(--ink);
    border-radius: 14px;
    padding: 1.75rem 2.5rem;
    max-width: 800px;
    width: 100%;
    text-align: center;
  }

  .header-eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.28em;
    opacity: 0.5;
    margin-bottom: 0.4rem;
  }

  .header-title {
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    letter-spacing: 0.06em;
    line-height: 1;
    margin: 0;
  }

  /* ── Events grid ── */
  .events-section {
    padding: 1.5rem 2rem 4rem;
    display: flex;
    justify-content: center;
  }

  .events-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    justify-content: center;
    max-width: 1100px;
    width: 100%;
  }

  /* ── Event card — mirrors ImplCard ── */
  .event-card {
    flex: 1;
    min-width: 280px;
    max-width: 340px;
    background: white;
    border: 3px solid var(--ink);
    border-radius: 10px;
    box-shadow: 4px 4px 0 var(--ink);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(16px);
    animation: card-in 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes card-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .event-header {
    padding: 10px 14px;
    border-bottom: 3px solid var(--ink);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    flex-shrink: 0;
  }

  .event-type {
    font-size: 0.5rem;
    letter-spacing: 0.15em;
    background: rgba(0, 0, 0, 0.18);
    padding: 2px 7px;
    border-radius: 3px;
  }

  .event-date {
    font-size: 1rem;
    letter-spacing: 0.06em;
  }

  .event-body {
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .event-title {
    font-size: 1.2rem;
    letter-spacing: 0.06em;
    line-height: 1.1;
    margin: 0;
  }

  .event-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .meta-chip {
    background: var(--ink);
    color: var(--bg);
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    padding: 3px 7px;
    border-radius: 3px;
  }

  .event-desc {
    font-size: 0.6rem;
    line-height: 1.7;
    color: var(--ink);
    border-top: 2px solid rgba(0, 0, 0, 0.1);
    padding-top: 8px;
    margin: 0;
    flex: 1;
  }

  .event-rsvp {
    display: inline-block;
    background: var(--ink);
    color: var(--bg);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    padding: 6px 14px;
    border-radius: 5px;
    text-decoration: none;
    align-self: flex-start;
    transition:
      transform 0.1s,
      box-shadow 0.1s;
    box-shadow: 3px 3px 0 rgba(0, 0, 0, 0.3);
  }
  .event-rsvp:hover {
    transform: translate(-1px, -1px);
    box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.3);
  }
  .event-rsvp:active {
    transform: translate(3px, 3px);
    box-shadow: 0 0 0 rgba(0, 0, 0, 0.3);
  }

  @media (max-width: 640px) {
    .event-card {
      min-width: 100%;
    }
  }
</style>
