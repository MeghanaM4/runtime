---
import Layout from "../layouts/Layout.astro";
import ImplCard from "../components/ImplCard.astro";
---

<Layout title="Dashboard">
  <main class="dashboard-page">
    <nav class="nav-bar">
      <a href="/generate" class="nav-back bebas">← BACK</a>
      <span class="nav-title bebas">RUNTIME</span>
    </nav>

    <div class="dashboard-div">
      <div class="dashboard-card">
        <div class="dashboard-eyebrow bebas">YOUR RUNTIME CHALLENGE</div>
        <p class="dashboard-text bebas" id="dashboard-text"></p>
      </div>
    </div>

    <div class="cards-div">
      <div class="cards-col">
        <ImplCard id="impl-input" color="var(--yellow)" typeLabel="INPUT" class="dashboard-impl-card" />
        <ImplCard id="impl-connector" color="var(--teal)" typeLabel="CONNECTOR" class="dashboard-impl-card" />
        <ImplCard id="impl-output" color="var(--orange)" typeLabel="OUTPUT" class="dashboard-impl-card" />
      </div>
    </div>
  </main>
</Layout>

<style>
  .dashboard-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  .nav-bar {
    background: var(--ink);
    color: var(--bg);
    display: flex;
    align-items: center;
    padding: 10px 24px;
    gap: 16px;
    flex-shrink: 0;
  }
  .nav-back {
    color: var(--yellow);
    text-decoration: none;
    font-size: 1.1rem;
    letter-spacing: 0.06em;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }
  .nav-back:hover {
    opacity: 0.7;
  }
  .nav-title {
    font-size: 1rem;
    letter-spacing: 0.08em;
    flex: 1;
    text-align: center;
  }

  .dashboard-div {
    display: flex;
    justify-content: center;
    padding: 3rem 2rem 2rem;
  }

  .dashboard-card {
    background: var(--ink);
    color: var(--bg);
    border: 4px solid var(--ink);
    border-radius: 14px;
    box-shadow: 8px 8px 0 var(--pink);
    padding: 2rem 2.5rem;
    max-width: 800px;
    width: 100%;
    text-align: center;
    animation: pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  .dashboard-eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.28em;
    opacity: 0.5;
    margin-bottom: 0.75rem;
  }

  .dashboard-text {
    font-size: clamp(1.4rem, 3.5vw, 2.2rem);
    line-height: 1.15;
    letter-spacing: 0.04em;
    margin: 0;
  }

  .dashboard-text .highlight-input {
    color: var(--yellow);
  }
  .dashboard-text .highlight-output {
    color: var(--orange);
  }
  .dashboard-text .highlight-connector {
    color: var(--teal);
  }

  .cards-div {
    display: flex;
    justify-content: center;
  }

  .cards-col {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
    max-width: 1100px;
    width: 80vw;
  }

  .dashboard-impl-card {
    flex: 1;
    min-width: 260px;
    max-width: 340px;
  }
</style>

<script>
  const stored = sessionStorage.getItem("runtimeChallenge");

  if (!stored) {
    window.location.href = "/generate";
  } else {
    const { input, output, connector } = JSON.parse(stored);

    const dashText = document.getElementById("dashboard-text")
    if(dashText) {
        dashText.innerHTML =
      `MAKE A PCB THAT TURNS ` +
      `<span class="highlight-input">${input.label}</span>` +
      ` INTO ` +
      `<span class="highlight-output">${output.label}</span>` +
      ` AND USES ` +
      `<span class="highlight-connector">${connector.label}</span>`;
    }

    const chipStyle = `
      background: var(--ink); color: var(--bg);
      font-family: 'Space Mono', monospace;
      font-size: 0.55rem; letter-spacing: 0.06em;
      padding: 3px 7px; border-radius: 3px;
    `;

    function populateCard(id: string, item: any) {
      const labelEl = document.getElementById(`${id}-label`);
      const chipsEl = document.getElementById(`${id}-chips`);
      const textEl = document.getElementById(`${id}-text`);
      
      if (labelEl) labelEl.textContent = item.label;
      if (chipsEl) chipsEl.innerHTML = item.components
        .map((c: string) => `<span style="${chipStyle}">${c}</span>`)
        .join("");
      if (textEl) textEl.textContent = item.implementation;
    }

    populateCard("impl-input", input);
    populateCard("impl-connector", connector);
    populateCard("impl-output", output);

    setTimeout(() => {
      const el = document.getElementById("impl-input");
      if (el) el.classList.add("visible");
    }, 100);
    setTimeout(() => {
      const el = document.getElementById("impl-connector");
      if (el) el.classList.add("visible");
    }, 220);
    setTimeout(() => {
      const el = document.getElementById("impl-output");
      if (el) el.classList.add("visible");
    }, 340);
  }
</script>
