---
import Layout from "../layouts/Layout.astro";
import ImplCard from "../components/ImplCard.astro";
---

<Layout title="Dashboard">
  <main class="dashboard-page">
    <nav class="nav-bar">
      <a href="/generate" class="nav-back bebas">← BACK</a>
      <span class="nav-title bebas">RUNTIME</span>
    </nav>

    <div
      class="absolute text-[1.5rem] mt-[4rem] gap-[1.5rem] flex flex-col w-full z-100 items-end"
    >
      <div class="cool-btn bebas bg-[#00c277] mr-[1rem]">
        <a
          class="p-[1rem] flex gap-[0.5rem] items-center justify-center"
          style="color:white; text-decoration: none;"
          href="/guide/step6"
        >
          <span>SUBMIT!</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="30"
            height="30"
            viewBox="0 0 24 24"
            ><!-- Icon from Tabler Icons by Paweł Kuna - https://github.com/tabler/tabler-icons/blob/master/LICENSE -->
            <g
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              ><path
                d="M19.875 6.27A2.23 2.23 0 0 1 21 8.218v7.284c0 .809-.443 1.555-1.158 1.948l-6.75 4.27a2.27 2.27 0 0 1-2.184 0l-6.75-4.27A2.23 2.23 0 0 1 3 15.502V8.217c0-.809.443-1.554 1.158-1.947l6.75-3.98a2.33 2.33 0 0 1 2.25 0l6.75 3.98z"
              ></path><path d="M10 16v-6a2 2 0 1 1 4 0v6m-4-3h4"></path></g
            ></svg
          >
        </a>
      </div>

      <div
        class="cool-btn bebas bg-[#e87500] mr-[1rem]"
      >
        <a class="p-[1rem] flex gap-[0.5rem] items-center justify-center" style="color:white; text-decoration: none" href="/guide/step1">
          <span>PCB GUIDE</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="30"
            height="30"
            viewBox="0 0 24 24"
            ><!-- Icon from Tabler Icons by Paweł Kuna - https://github.com/tabler/tabler-icons/blob/master/LICENSE -->
            <g
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              ><path
                d="M19.875 6.27A2.23 2.23 0 0 1 21 8.218v7.284c0 .809-.443 1.555-1.158 1.948l-6.75 4.27a2.27 2.27 0 0 1-2.184 0l-6.75-4.27A2.23 2.23 0 0 1 3 15.502V8.217c0-.809.443-1.554 1.158-1.947l6.75-3.98a2.33 2.33 0 0 1 2.25 0l6.75 3.98z"
              ></path><path d="M10 16h2a2 2 0 1 0 0-4h-2h2a2 2 0 1 0 0-4h-2z"
              ></path></g
            ></svg
          >
        </a>
      </div>
    </div>

    <!-- <div
      class="fixed left-[2rem] mt-[4rem] z-100 flex flex-col h-min justify-end w-min"
    >
      <a
        href="/calendar"
        class="cool-btn bebas bg-[#ff3560] w-min p-[1rem] flex gap-[0.5rem] items-center justify-center"
        style="border-radius: 1.5rem; text-decoration: none; color:white"
        id="calendar-btn"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 24 24"
          >
          <path
            fill="currentColor"
            d="M5 22q-.825 0-1.412-.587T3 20V6q0-.825.588-1.412T5 4h1V3q0-.425.288-.712T7 2t.713.288T8 3v1h8V3q0-.425.288-.712T17 2t.713.288T18 3v1h1q.825 0 1.413.588T21 6v14q0 .825-.587 1.413T19 22zm0-2h14V10H5zM5 8h14V6H5zm0 0V6zm7 6q-.425 0-.712-.288T11 13t.288-.712T12 12t.713.288T13 13t-.288.713T12 14m-4 0q-.425 0-.712-.288T7 13t.288-.712T8 12t.713.288T9 13t-.288.713T8 14m8 0q-.425 0-.712-.288T15 13t.288-.712T16 12t.713.288T17 13t-.288.713T16 14m-4 4q-.425 0-.712-.288T11 17t.288-.712T12 16t.713.288T13 17t-.288.713T12 18m-4 0q-.425 0-.712-.288T7 17t.288-.712T8 16t.713.288T9 17t-.288.713T8 18m8 0q-.425 0-.712-.288T15 17t.288-.712T16 16t.713.288T17 17t-.288.713T16 18"
          ></path></svg
        >
      </a>
    </div> -->

    <div class="dashboard-div">
      <div class="dashboard-card">
        <p class="dashboard-text bebas" id="dashboard-text"></p>
      </div>
    </div>

    <div class="dashboard-columns">
      <div class="dashboard-col-cards">
        <ImplCard
          id="impl-input"
          color="var(--yellow)"
          typeLabel="INPUT"
          class="dashboard-impl-card"
        />
        <ImplCard
          id="impl-connector"
          color="var(--teal)"
          typeLabel="CONNECTOR"
          class="dashboard-impl-card"
        />
        <ImplCard
          id="impl-output"
          color="var(--orange)"
          typeLabel="OUTPUT"
          class="dashboard-impl-card"
        />
      </div>

      <div class="criteria-card">
        <p class="criteria-heading bebas mb-[1rem]">what you need to submit</p>

        <ul class="criteria-list">
          <li>
            <span class="criteria-box"></span>
            <span>A <strong>public GitHub repo</strong> with your README, project files, production files, firmware, and <span class="criteria-code">journal.md</span> — commit progress often, don't dump it all in one commit at the end</span>
          </li>
          <li>
            <span class="criteria-box"></span>
            <span>Track your time with <span class="criteria-code">journal.md</span> or <a href="https://lookout.hackclub.com" target="_blank" rel="noopener" class="criteria-link">Lookout</a> — each journal entry titled with how much time you spent that session, with 2-4 screenshots per entry</span>
          </li>
          <li>
            <span class="criteria-box"></span>
            <span>A good README with your input/output/connector, a short description of your board, PCB screenshots, and a BOM (bill of materials)</span>
          </li>
        </ul>

        <p class="criteria-note">Write journal entries like you're explaining the session to someone else, not logging a timestamp — "worked on schematic, 1h" tells nobody anything. What did you actually figure out? What are you stuck on?</p>
      </div>
    </div>
  </main>
</Layout>

<style>
  .dashboard-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  .nav-bar {
    background: var(--ink);
    color: var(--bg);
    display: flex;
    align-items: center;
    padding: 10px 24px;
    gap: 16px;
    flex-shrink: 0;
  }
  .nav-back {
    color: var(--yellow);
    text-decoration: none;
    font-size: 1.1rem;
    letter-spacing: 0.06em;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }
  .nav-back:hover {
    opacity: 0.7;
  }
  .nav-title {
    font-size: 1rem;
    letter-spacing: 0.08em;
    flex: 1;
    text-align: center;
  }

  .dashboard-div {
    display: flex;
    justify-content: center;
    padding: 3rem 2rem 2rem;
  }

  .dashboard-card {
    background: var(--ink);
    color: var(--bg);
    border: 4px solid var(--ink);
    border-radius: 14px;
    padding: 2rem 2.5rem;
    max-width: 800px;
    width: 100%;
    text-align: center;
  }

  .dashboard-eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.28em;
    opacity: 0.5;
    margin-bottom: 0.75rem;
  }

  .dashboard-text {
    font-size: clamp(1.4rem, 3.5vw, 2.2rem);
    line-height: 1.15;
    letter-spacing: 0.04em;
    margin: 0;
  }

  .dashboard-text .highlight-input {
    color: yellow;
  }
  .dashboard-text .highlight-output {
    color: var(--orange);
  }
  .dashboard-text .highlight-connector {
    color: var(--teal);
  }

  .dashboard-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: start;
    gap:5rem;
    max-width: 1200px;
    width: 90vw;
    margin: 1rem auto 4rem;
  }
  @media (max-width: 900px) {
    .dashboard-columns {
      grid-template-columns: 1fr;
      width: 92vw;
    }
  }

  .dashboard-col-cards {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .dashboard-impl-card {
    width: 100%;
    min-width: 0;
    max-width: none;
  }

  .cool-btn {
    border: 4px solid var(--ink);
    border-radius: 8px;
    box-shadow: 6px 6px 0 var(--ink);
    letter-spacing: 0.1em;
    transition:
      transform 0.1s,
      box-shadow 0.1s,
      background 0.15s;
  }
  
  .cool-btn:hover:not(:disabled) {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0 var(--ink);
  }
  .cool-btn:active:not(:disabled) {
    transform: translate(6px, 6px);
    box-shadow: 0 0 0 var(--ink);
  }
  .cool-btn:disabled {
    background: #bbb;
    cursor: not-allowed;
    box-shadow: 3px 3px 0 var(--ink);
    color: #888;
  }

  /* ---------- submission criteria (pulled from guide step1 + step6) ---------- */
  .criteria-card {
    background: var(--ink);
    color: var(--bg);
    border: 4px solid var(--ink);
    border-radius: 14px;
    padding: 2rem 2.5rem;
    width: 100%;
    height: max-content;
  }

  .criteria-heading {
    font-size: 1.6rem;
    letter-spacing: 0.08em;
  }

  .criteria-sub {
    font-family: "Space Mono", monospace;
    font-size: 0.75rem;
    opacity: 0.55;
    margin: 0 0 1.5rem;
  }

  .criteria-list {
    list-style: none;
    margin: 0 0 1.25rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .criteria-list li {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .criteria-box {
    flex: none;
    width: 18px;
    height: 18px;
    margin-top: 3px;
    border: 2.5px solid var(--bg);
    border-radius: 4px;
  }

  .criteria-code {
    font-family: "Space Mono", monospace;
    font-size: 0.85em;
    background: rgba(255, 255, 255, 0.12);
    padding: 1px 6px;
    border-radius: 4px;
  }

  .criteria-link {
    color: var(--teal);
    text-decoration: underline;
  }

  .criteria-note {
    font-size: 0.85rem;
    opacity: 0.75;
    line-height: 1.5;
    border-top: 2px dashed rgba(255, 255, 255, 0.2);
    padding-top: 1rem;
  }

  .criteria-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .criteria-btn {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    padding: 0.7rem 1.4rem;
    font-size: 0.95rem;
  }

  .criteria-btn-teal {
    background: var(--teal);
    color: var(--ink);
  }

  .criteria-btn-green {
    background: #22c55e;
    color: white;
  }
</style>

<script>
  const stored = localStorage.getItem("runtimeChallenge");

  if (!stored) {
    window.location.href = "/generate";
  } else {
    const { input, output, connector } = JSON.parse(stored);

    const dashText = document.getElementById("dashboard-text");
    if (dashText) {
      dashText.innerHTML =
        `MAKE A PCB THAT TURNS ` +
        `<span class="highlight-input">${localStorage.getItem("input")}</span>` +
        ` INTO ` +
        `<span class="highlight-output color-yellow">${localStorage.getItem("output")}</span>` +
        ` AND USES A ` +
        `<span class="highlight-connector">${localStorage.getItem("connector")}</span>`;
    }

    const chipStyle = `
      background: var(--ink); color: var(--bg);
      font-family: 'Space Mono', monospace;
      font-size: 0.55rem; letter-spacing: 0.06em;
      padding: 3px 7px; border-radius: 3px;
    `;

    function populateCard(id: string, item: any) {
      const labelEl = document.getElementById(`${id}-label`);
      const chipsEl = document.getElementById(`${id}-chips`);
      const textEl = document.getElementById(`${id}-text`);

      if (labelEl) labelEl.textContent = item.label;
      if (chipsEl)
        chipsEl.innerHTML = item.components
          .map((c: string) => `<span style="${chipStyle}">${c}</span>`)
          .join("");
      if (textEl) textEl.textContent = item.implementation;
    }

    populateCard("impl-input", input);
    populateCard("impl-connector", connector);
    populateCard("impl-output", output);

    setTimeout(() => {
      const el = document.getElementById("impl-input");
      if (el) el.classList.add("visible");
    }, 100);
    setTimeout(() => {
      const el = document.getElementById("impl-connector");
      if (el) el.classList.add("visible");
    }, 220);
    setTimeout(() => {
      const el = document.getElementById("impl-output");
      if (el) el.classList.add("visible");
    }, 340);
  }
</script>