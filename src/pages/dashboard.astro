---
import Layout from "../layouts/Layout.astro";
import params from "../data/parameters.json";

const { inputs, outputs, connectors } = params;
---

<Layout title="Dashboard">
  <main class="dashboard-page">
    <nav class="nav-bar">
      <a href="/generate" class="nav-back bebas">← BACK</a>
      <span class="nav-title bebas">RUNTIME</span>
    </nav>

    <section class="dashboard-section">
      <div class="dashboard-card">
        <div class="dashboard-eyebrow bebas">YOUR RUNTIME CHALLENGE</div>
        <p class="dashboard-text bebas" id="dashboard-text"></p>
      </div>
    </section>

    <section class="cards-section">
      <div class="cards-row" id="cards-row"></div>
    </section>
  </main>
</Layout>

<style>
  .dashboard-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  .nav-bar {
    background: var(--ink);
    color: var(--bg);
    display: flex;
    align-items: center;
    padding: 10px 24px;
    gap: 16px;
    flex-shrink: 0;
  }
  .nav-back {
    color: var(--yellow);
    text-decoration: none;
    font-size: 1.1rem;
    letter-spacing: 0.06em;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }
  .nav-back:hover {
    opacity: 0.7;
  }
  .nav-title {
    font-size: 1rem;
    letter-spacing: 0.08em;
    flex: 1;
    text-align: center;
  }

  .dashboard-section {
    display: flex;
    justify-content: center;
    padding: 3rem 2rem 2rem;
  }

  .dashboard-card {
    background: var(--ink);
    color: var(--bg);
    border: 4px solid var(--ink);
    border-radius: 14px;
    box-shadow: 8px 8px 0 var(--pink);
    padding: 2rem 2.5rem;
    max-width: 800px;
    width: 100%;
    text-align: center;
    animation: pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  .dashboard-eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.28em;
    opacity: 0.5;
    margin-bottom: 0.75rem;
  }

  .dashboard-text {
    font-size: clamp(1.4rem, 3.5vw, 2.2rem);
    line-height: 1.15;
    letter-spacing: 0.04em;
    margin: 0;
  }

  .dashboard-text .highlight-input {
    color: var(--yellow);
  }
  .dashboard-text .highlight-output {
    color: var(--orange);
  }
  .dashboard-text .highlight-connector {
    color: var(--teal);
  }

  .cards-section {
    padding: 0 2rem 3rem;
    display: flex;
    justify-content: center;
  }

  .cards-row {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
    max-width: 1100px;
    width: 100%;
  }

  .impl-card {
    flex: 1;
    min-width: 260px;
    max-width: 340px;
    background: white;
    border: 3px solid var(--ink);
    border-radius: 10px;
    box-shadow: 4px 4px 0 var(--ink);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(20px);
    animation: card-appear 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  .impl-card:nth-child(1) { animation-delay: 0.1s; }
  .impl-card:nth-child(2) { animation-delay: 0.2s; }
  .impl-card:nth-child(3) { animation-delay: 0.3s; }

  @keyframes card-appear {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .card-header {
    padding: 10px 14px;
    border-bottom: 3px solid var(--ink);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .card-type-badge {
    font-family: "Space Mono", monospace;
    font-size: 0.5rem;
    letter-spacing: 0.15em;
    background: rgba(0, 0, 0, 0.18);
    padding: 2px 6px;
    border-radius: 3px;
  }

  .card-title {
    font-size: 1.2rem;
    letter-spacing: 0.08em;
  }

  .card-body {
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .impl-tag {
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    opacity: 0.5;
    display: block;
    margin-bottom: 4px;
  }

  .impl-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-bottom: 4px;
  }

  .chip {
    background: var(--ink);
    color: var(--bg);
    font-family: "Space Mono", monospace;
    font-size: 0.55rem;
    letter-spacing: 0.06em;
    padding: 3px 7px;
    border-radius: 3px;
  }

  .impl-text {
    font-size: 0.62rem;
    line-height: 1.65;
    border-top: 2px solid rgba(0, 0, 0, 0.1);
    padding-top: 8px;
    color: var(--ink);
  }
</style>

<script define:vars={{ inputs, outputs, connectors }}>
  const urlParams = new URLSearchParams(window.location.search);
  const inputId = urlParams.get("input");
  const outputId = urlParams.get("output");
  const connectorId = urlParams.get("connector");

  const inputItem = inputs.find((i) => i.id === inputId);
  const outputItem = outputs.find((i) => i.id === outputId);
  const connectorItem = connectors.find((i) => i.id === connectorId);

  if (!inputItem || !outputItem || !connectorItem) {
    window.location.href = "/generate";
  } else {
    const dashboardText = document.getElementById("dashboard-text");
    dashboardText.innerHTML =
      `MAKE A PCB THAT TURNS ` +
      `<span class="highlight-input">${inputItem.label}</span>` +
      ` INTO ` +
      `<span class="highlight-output">${outputItem.label}</span>` +
      ` AND USES ` +
      `<span class="highlight-connector">${connectorItem.label}</span>`;

    function renderCard(item, color, typeLabel) {
      return `
        <div class="impl-card">
          <div class="card-header" style="background: ${color}">
            <span class="card-type-badge">${typeLabel}</span>
            <span class="card-title bebas">${item.label}</span>
          </div>
          <div class="card-body">
            <div>
              <span class="impl-tag bebas">COMPONENTS</span>
              <div class="impl-chips">
                ${item.components.map((c) => `<span class="chip">${c}</span>`).join("")}
              </div>
            </div>
            <div class="impl-text">${item.implementation}</div>
          </div>
        </div>
      `;
    }

    const cardsRow = document.getElementById("cards-row");
    cardsRow.innerHTML =
      renderCard(inputItem, "var(--yellow)", "INPUT") +
      renderCard(connectorItem, "var(--teal)", "CONNECTOR") +
      renderCard(outputItem, "var(--orange)", "OUTPUT");
  }
</script>
