---
import Layout from "../layouts/Layout.astro";
import ImplCard from "../components/ImplCard.astro";
---

<Layout title="Dashboard">
  <main class="dashboard-page">
    <nav class="nav-bar">
      <a href="/generate" class="nav-back bebas">← BACK</a>
      <span class="nav-title bebas">RUNTIME</span>
    </nav>

    <div
      class="fixed right-[2rem] mt-[4rem] z-100 flex flex-col h-min justify-end w-min"
    >
      <button
        class="cool-btn bebas bg-[#00c277] w-min p-[1rem] flex gap-[0.5rem] items-center justify-center"
        type="button"
      >
        <span id="spin-btn-text">SUBMIT!</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"><!-- Icon from Tabler Icons by Paweł Kuna - https://github.com/tabler/tabler-icons/blob/master/LICENSE --><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M19.875 6.27A2.23 2.23 0 0 1 21 8.218v7.284c0 .809-.443 1.555-1.158 1.948l-6.75 4.27a2.27 2.27 0 0 1-2.184 0l-6.75-4.27A2.23 2.23 0 0 1 3 15.502V8.217c0-.809.443-1.554 1.158-1.947l6.75-3.98a2.33 2.33 0 0 1 2.25 0l6.75 3.98z"/><path d="M10 16v-6a2 2 0 1 1 4 0v6m-4-3h4"/></g></svg>
      </button>

      <button
        class="cool-btn bebas mt-[2rem] bg-[#e87500] w-min ml-[1.4rem] p-[1rem] flex gap-[0.5rem] items-center justify-center"
        type="button"
      >
        <span id="spin-btn-text">PCB GUIDE</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24"><!-- Icon from Tabler Icons by Paweł Kuna - https://github.com/tabler/tabler-icons/blob/master/LICENSE --><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M19.875 6.27A2.23 2.23 0 0 1 21 8.218v7.284c0 .809-.443 1.555-1.158 1.948l-6.75 4.27a2.27 2.27 0 0 1-2.184 0l-6.75-4.27A2.23 2.23 0 0 1 3 15.502V8.217c0-.809.443-1.554 1.158-1.947l6.75-3.98a2.33 2.33 0 0 1 2.25 0l6.75 3.98z"/><path d="M10 16h2a2 2 0 1 0 0-4h-2h2a2 2 0 1 0 0-4h-2z"/></g></svg>
      </button>
    </div>

    <div class="dashboard-div">
      <div class="dashboard-card">
        <p class="dashboard-text bebas" id="dashboard-text"></p>
      </div>
    </div>

    <div class="cards-div mb-[4rem]">
      <div class="cards-col">
        <ImplCard
          id="impl-input"
          color="var(--yellow)"
          typeLabel="INPUT"
          class="dashboard-impl-card"
        />
        <ImplCard
          id="impl-connector"
          color="var(--teal)"
          typeLabel="CONNECTOR"
          class="dashboard-impl-card"
        />
        <ImplCard
          id="impl-output"
          color="var(--orange)"
          typeLabel="OUTPUT"
          class="dashboard-impl-card"
        />
      </div>
    </div>
  </main>
</Layout>

<style>
  .dashboard-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  .nav-bar {
    background: var(--ink);
    color: var(--bg);
    display: flex;
    align-items: center;
    padding: 10px 24px;
    gap: 16px;
    flex-shrink: 0;
  }
  .nav-back {
    color: var(--yellow);
    text-decoration: none;
    font-size: 1.1rem;
    letter-spacing: 0.06em;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }
  .nav-back:hover {
    opacity: 0.7;
  }
  .nav-title {
    font-size: 1rem;
    letter-spacing: 0.08em;
    flex: 1;
    text-align: center;
  }

  .dashboard-div {
    display: flex;
    justify-content: center;
    padding: 3rem 2rem 2rem;
  }

  .dashboard-card {
    background: var(--ink);
    color: var(--bg);
    border: 4px solid var(--ink);
    border-radius: 14px;
    padding: 2rem 2.5rem;
    max-width: 800px;
    width: 100%;
    text-align: center;
  }

  .dashboard-eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.28em;
    opacity: 0.5;
    margin-bottom: 0.75rem;
  }

  .dashboard-text {
    font-size: clamp(1.4rem, 3.5vw, 2.2rem);
    line-height: 1.15;
    letter-spacing: 0.04em;
    margin: 0;
  }

  .dashboard-text .highlight-input {
    color: yellow;
  }
  .dashboard-text .highlight-output {
    color: var(--orange);
  }
  .dashboard-text .highlight-connector {
    color: var(--teal);
  }

  .cards-div {
    display: flex;
    justify-content: center;
  }

  .cards-col {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
    max-width: 1100px;
    width: 80vw;
  }

  .dashboard-impl-card {
    flex: 1;
    min-width: 260px;
    max-width: 340px;
  }

  .cool-btn {
    color: white;
    border: 4px solid var(--ink);
    border-radius: 8px;
    box-shadow: 6px 6px 0 var(--ink);
    font-size: 2rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition:
      transform 0.1s,
      box-shadow 0.1s,
      background 0.15s;
    user-select: none;
  }
  .cool-btn:hover:not(:disabled) {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0 var(--ink);
  }
  .cool-btn:active:not(:disabled) {
    transform: translate(6px, 6px);
    box-shadow: 0 0 0 var(--ink);
  }
  .cool-btn:disabled {
    background: #bbb;
    cursor: not-allowed;
    box-shadow: 3px 3px 0 var(--ink);
    color: #888;
  }
</style>

<script>
  const stored = sessionStorage.getItem("runtimeChallenge");

  if (!stored) {
    window.location.href = "/generate";
  } else {
    const { input, output, connector } = JSON.parse(stored);

    const dashText = document.getElementById("dashboard-text");
    if (dashText) {
      dashText.innerHTML =
        `MAKE A PCB THAT TURNS ` +
        `<span class="highlight-input">${input.label}</span>` +
        ` INTO ` +
        `<span class="highlight-output color-yellow">${output.label}</span>` +
        ` AND USES A ` +
        `<span class="highlight-connector">${connector.label}</span>`;
    }

    const chipStyle = `
      background: var(--ink); color: var(--bg);
      font-family: 'Space Mono', monospace;
      font-size: 0.55rem; letter-spacing: 0.06em;
      padding: 3px 7px; border-radius: 3px;
    `;

    function populateCard(id: string, item: any) {
      const labelEl = document.getElementById(`${id}-label`);
      const chipsEl = document.getElementById(`${id}-chips`);
      const textEl = document.getElementById(`${id}-text`);

      if (labelEl) labelEl.textContent = item.label;
      if (chipsEl)
        chipsEl.innerHTML = item.components
          .map((c: string) => `<span style="${chipStyle}">${c}</span>`)
          .join("");
      if (textEl) textEl.textContent = item.implementation;
    }

    populateCard("impl-input", input);
    populateCard("impl-connector", connector);
    populateCard("impl-output", output);

    setTimeout(() => {
      const el = document.getElementById("impl-input");
      if (el) el.classList.add("visible");
    }, 100);
    setTimeout(() => {
      const el = document.getElementById("impl-connector");
      if (el) el.classList.add("visible");
    }, 220);
    setTimeout(() => {
      const el = document.getElementById("impl-output");
      if (el) el.classList.add("visible");
    }, 340);
  }
</script>
