---
import Layout from "../layouts/Layout.astro";
import ImplCard from "../components/ImplCard.astro";
import params from "../data/parameters.json";
import FuzzyText from "../components/FuzzyText";

const { inputs, outputs, connectors } = params;
---

<Layout title="Get Your Parameters">
  <main class="generate-page h-[100vh]">
    <nav class="nav-bar">
      <a href="/" class="nav-back bebas">← BACK</a>
      <span class="nav-title bebas">RUNTIME</span>
      <div class="rolls-indicator" id="rolls-indicator">
        <span class="rolls-label">ROLLS LEFT:</span>
        <span class="roll-pip" id="pip-0"></span>
        <span class="roll-pip" id="pip-1"></span>
        <span class="roll-pip" id="pip-2"></span>
      </div>
    </nav>

    <div class="w-full flex items-center justify-center text-[1.5rem]" style="margin-top: calc(10vh - 1rem); margin-bottom: calc(10vh - 1rem)">
      <FuzzyText
          text="spin the machine for your parts!"
          client:idle
          baseIntensity={0.05}
          hoverIntensity={0.15}
          color="#000000"
          fontSize="2rem"
          clickEffect="true"
          className="w-fit"
        />
    </div>

    <div class="machines-div h-fit">
      <div class="machines-row h-fit">
        <!-- INPUT — Plug -->
        <div class="machine-col">
          <div class="machine" id="machine-input">
            <div class="plug-body machine-body">
              <div class="machine-top-label bebas">INPUT</div>
              <div class="slot-window" id="window-input">
                <div class="slot-strip" id="strip-input"></div>
              </div>
              <div class="plug-dots" aria-hidden="true">
                <span></span><span></span><span></span>
              </div>
            </div>
          </div>
          <div class="machine-label bebas" style="color: var(--yellow)">
            INPUT
          </div>
          <ImplCard
            id="impl-input"
            color="var(--yellow)"
            typeLabel="INPUT"
            class="w-[250px]"
          />
        </div>

        <!-- CONNECTOR — Monitor -->
        <div class="machine-col">
          <div class="machine monitor-machine" id="machine-connector">
            <div class="monitor-antennae" aria-hidden="true">
              <div class="antenna left"></div>
              <div class="antenna right"></div>
            </div>
            <div class="monitor-body machine-body">
              <div class="machine-top-label bebas">CONNECTOR</div>
              <div class="monitor-bezel">
                <div class="slot-window dark-window" id="window-connector">
                  <div class="slot-strip" id="strip-connector"></div>
                </div>
                <div class="power-led" aria-hidden="true"></div>
              </div>
            </div>
            <div class="monitor-stand" aria-hidden="true">
              <div class="stand-neck"></div>
              <div class="stand-base"></div>
            </div>
          </div>
          <div class="machine-label bebas" style="color: var(--teal)">
            CONNECTOR
          </div>
          <ImplCard
            id="impl-connector"
            color="var(--teal)"
            typeLabel="CONNECTOR"
            class="w-[300px]"
          />
        </div>

        <!-- OUTPUT — Speaker -->
        <div class="machine-col">
          <div class="machine speaker-machine" id="machine-output">
            <div class="speaker-body machine-body">
              <div class="machine-top-label bebas">OUTPUT</div>
              <div class="slot-window" id="window-output">
                <div class="slot-strip" id="strip-output"></div>
              </div>
              <div class="speaker-grille" aria-hidden="true">
                <div class="grille-line"></div>
                <div class="grille-line"></div>
                <div class="grille-line"></div>
                <div class="grille-line"></div>
              </div>
            </div>
          </div>
          <div class="machine-label bebas" style="color: var(--orange)">
            OUTPUT
          </div>
          <ImplCard
            id="impl-output"
            color="var(--orange)"
            typeLabel="OUTPUT"
            class="w-[250px]"
          />
        </div>
      </div>
    </div>

    <div class="controls-div">
      <button
        class="spin-btn bebas flex items-center justify-center gap-[0.5rem]"
        id="spin-btn"
        type="button"
      >
        <span id="spin-btn-text">SPIN!</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 24 24"
          ><!-- Icon from Unicons by Iconscout - https://github.com/Iconscout/unicons/blob/master/LICENSE -->
          <path
            fill="currentColor"
            d="M19 6a1 1 0 0 0-1 1v4a1 1 0 0 1-1 1H7.41l1.3-1.29a1 1 0 0 0-1.42-1.42l-3 3a1 1 0 0 0-.21.33a1 1 0 0 0 0 .76a1 1 0 0 0 .21.33l3 3a1 1 0 0 0 1.42 0a1 1 0 0 0 0-1.42L7.41 14H17a3 3 0 0 0 3-3V7a1 1 0 0 0-1-1"
          ></path></svg
        >
      </button>

      <a
        href="/dashboard"
        class="get-started-btn bebas flex gap-[0.5rem] justify-center items-center"
        id="get-started-btn"
        hidden
      >
        <span>GET STARTED</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="32"
          height="32"
          viewBox="0 0 24 24"
          ><!-- Icon from Tabler Icons by Paweł Kuna - https://github.com/tabler/tabler-icons/blob/master/LICENSE -->
          <g
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            ><path
              d="M19.875 6.27A2.23 2.23 0 0 1 21 8.218v7.284c0 .809-.443 1.555-1.158 1.948l-6.75 4.27a2.27 2.27 0 0 1-2.184 0l-6.75-4.27A2.23 2.23 0 0 1 3 15.502V8.217c0-.809.443-1.554 1.158-1.947l6.75-3.98a2.33 2.33 0 0 1 2.25 0l6.75 3.98z"
            ></path><path d="M10 16v-6a2 2 0 1 1 4 0v6m-4-3h4"></path></g
          ></svg
        >
      </a>
    </div>
  </main>
</Layout>

<style>
  .generate-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  .nav-bar {
    background: var(--ink);
    color: var(--bg);
    display: flex;
    align-items: center;
    padding: 10px 24px;
    gap: 16px;
    flex-wrap: wrap;
    flex-shrink: 0;
  }
  .nav-back {
    color: var(--yellow);
    text-decoration: none;
    font-size: 1.1rem;
    letter-spacing: 0.06em;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }
  .nav-back:hover {
    opacity: 0.7;
  }
  .nav-title {
    font-size: 1rem;
    letter-spacing: 0.08em;
    flex: 1;
    text-align: center;
  }

  .rolls-indicator {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .rolls-label {
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    color: #888;
    font-family: "Space Mono", monospace;
  }
  .roll-pip {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2.5px solid var(--yellow);
    background: var(--yellow);
    transition:
      background 0.3s,
      border-color 0.3s;
  }
  .roll-pip.used {
    background: transparent;
    border-color: #555;
  }

  .machines-div {
    flex: 1;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    margin-top: calc(15vh - 100px);
    overflow-x: none;
    overflow-y: none;
  }

  .machines-row {
    display: flex;
    align-items: flex-start;
    gap: calc(10vw - 100px);
  }

  .machine-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    width: fit-content;
  }

  .machine-label {
    font-size: 1.1rem;
    letter-spacing: 0.1em;
  }

  .machine {
    display: flex;
    align-items: center;
  }
  .machine.spinning .machine-body {
    animation: shake 0.12s ease-in-out infinite;
  }

  .machine-body {
    width: 15vw;
    height: 40vh;
    border: 4px solid var(--ink);
    border-radius: 4px;
    box-shadow: 7px 7px 0 var(--ink);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    overflow: hidden;
    position: relative;
  }

  .machine-top-label {
    text-align: center;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    padding: 5px 12px 4px;
    background: rgba(0, 0, 0, 0.14);
    border-bottom: 3px solid var(--ink);
    flex-shrink: 0;
  }

  .slot-window {
    flex: 1;
    overflow: hidden;
    position: relative;
  }
  .dark-window {
    border: 3px solid var(--ink);
    border-radius: 4px;
    background: #0a1628;
  }

  .slot-strip {
    display: flex;
    flex-direction: column;
    transform: translateY(0);
    will-change: transform;
  }

  .plug-body {
    background: var(--yellow);
  }
  .plug-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 8px;
    flex-shrink: 0;
  }
  .plug-dots span {
    width: 7px;
    height: 7px;
    background: var(--ink);
    border-radius: 50%;
    opacity: 0.35;
  }

  .monitor-machine {
    flex-direction: column;
    align-items: center;
  }
  .monitor-antennae {
    display: flex;
    gap: 26px;
    margin-bottom: -3px;
    z-index: 1;
  }
  .antenna {
    width: 7px;
    background: var(--ink);
    border-radius: 4px 4px 0 0;
  }
  .antenna.left {
    height: 38px;
    transform: rotate(-10deg);
    transform-origin: bottom center;
  }
  .antenna.right {
    height: 38px;
    transform: rotate(10deg);
    transform-origin: bottom center;
  }
  .monitor-body {
    background: var(--teal);
    width: 230px;
  }
  .monitor-bezel {
    flex: 1;
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .monitor-bezel .slot-window {
    flex: 1;
  }
  .power-led {
    width: 8px;
    height: 8px;
    background: rgb(149, 255, 123);
    border-radius: 50%;
    margin-left: auto;
    flex-shrink: 0;
  }

  @keyframes led-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }
  .monitor-stand {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .stand-neck {
    width: 18px;
    height: 18px;
    background: var(--ink);
  }
  .stand-base {
    width: 72px;
    height: 10px;
    background: var(--ink);
    border-radius: 0 0 4px 4px;
  }

  .speaker-body {
    background: var(--orange);
  }
  .speaker-grille {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 8px 16px;
    flex-shrink: 0;
  }
  .grille-line {
    height: 4px;
    background: rgba(0, 0, 0, 0.2);
    border-radius: 2px;
  }

  .controls-div {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .spin-btn {
    background: var(--pink);
    margin-bottom: 2rem;
    margin-top: -5rem;
    height: min-content;
    color: white;
    border: 4px solid var(--ink);
    border-radius: 8px;
    box-shadow: 6px 6px 0 var(--ink);
    padding: 14px 48px;
    font-size: 2rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition:
      transform 0.1s,
      box-shadow 0.1s,
      background 0.15s;
    user-select: none;
    flex-shrink: 0;
  }
  .spin-btn:hover:not(:disabled) {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0 var(--ink);
    background: #ff1a47;
  }
  .spin-btn:active:not(:disabled) {
    transform: translate(6px, 6px);
    box-shadow: 0 0 0 var(--ink);
  }
  .spin-btn:disabled {
    background: #bbb;
    cursor: not-allowed;
    box-shadow: 3px 3px 0 var(--ink);
    color: #888;
  }

  .get-started-btn {
    background: var(--green);
    margin-left: auto;
    margin-bottom: 2rem;
    margin-right: 2rem;
    color: var(--ink);
    border: 4px solid var(--ink);
    border-radius: 8px;
    box-shadow: 6px 6px 0 var(--ink);
    padding: 14px 28px;
    font-size: 1.5rem;
    letter-spacing: 0.08em;
    text-decoration: none;
    flex-shrink: 0;
    transition:
      transform 0.1s,
      box-shadow 0.1s;
  }
  .get-started-btn[hidden] {
    display: none !important;
  }
  .get-started-btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0 var(--ink);
  }
  .get-started-btn:active {
    transform: translate(6px, 6px);
    box-shadow: 0 0 0 var(--ink);
  }
</style>

<script define:vars={{ inputs, outputs, connectors }}>

  const ITEM_H = 150;
  const REPEATS = 7;
  const MAX_ROLLS = 3;

  let rollsUsed = 0;
  let isSpinning = false;

  const spinBtn = document.getElementById("spin-btn");
  const spinBtnText = document.getElementById("spin-btn-text");
  const getStartedBtn = document.getElementById("get-started-btn");

  const machines = {
    input: {
      strip: document.getElementById("strip-input"),
      el: document.getElementById("machine-input"),
      impl: document.getElementById("impl-input"),
      label: document.getElementById("impl-input-label"),
      chips: document.getElementById("impl-input-chips"),
      text: document.getElementById("impl-input-text"),
      items: inputs,
    },
    output: {
      strip: document.getElementById("strip-output"),
      el: document.getElementById("machine-output"),
      impl: document.getElementById("impl-output"),
      label: document.getElementById("impl-output-label"),
      chips: document.getElementById("impl-output-chips"),
      text: document.getElementById("impl-output-text"),
      items: outputs,
    },
    connector: {
      strip: document.getElementById("strip-connector"),
      el: document.getElementById("machine-connector"),
      impl: document.getElementById("impl-connector"),
      label: document.getElementById("impl-connector-label"),
      chips: document.getElementById("impl-connector-chips"),
      text: document.getElementById("impl-connector-text"),
      items: connectors,
    },
  };

  function buildStrip(stripEl, items) {
    const all = Array.from({ length: REPEATS }, () => items).flat();
    stripEl.innerHTML = all
      .map(
        (item) => `
      <div style="
        height: ${ITEM_H}px;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: 6px; padding: 10px 8px; user-select: none;
      ">
        <div style="
          width: 80px; height: 80px; position: relative;
          display: flex; align-items: center; justify-content: center;
          background: rgba(0,0,0,0.08); border-radius: 8px; overflow: hidden; flex-shrink: 0;
        ">
          <img
            src="${item.image}"
            alt="${item.label}"
            style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; padding: 6px;"
            onerror="this.style.display='none'"
          >
        </div>
        <span style="
          font-family: 'Bebas Neue', sans-serif;
          font-size: 1.1rem; letter-spacing: 0.06em; color: white; text-align: center; line-height: 1.1;
        ">${item.label}</span>
      </div>
    `,
      )
      .join("");
    stripEl.style.transition = "none";
    stripEl.style.transform = "translateY(0)";
  }

  async function spinStrip(stripEl, items, duration) {
    const selected = Math.floor(Math.random() * items.length);
    const rotations = 4 + Math.floor(Math.random() * 2);
    const totalY = (rotations * items.length + selected) * ITEM_H;

    stripEl.style.transition = "none";
    stripEl.style.transform = "translateY(0)";
    void stripEl.offsetHeight;

    stripEl.style.transition = `transform ${duration}ms cubic-bezier(0.22, 0.88, 0.26, 1)`;
    stripEl.style.transform = `translateY(-${totalY}px)`;
    await sleep(duration);

    stripEl.style.transition = "transform 80ms ease-out";
    stripEl.style.transform = `translateY(-${totalY + 12}px)`;
    await sleep(85);
    stripEl.style.transition = "transform 100ms ease-out";
    stripEl.style.transform = `translateY(-${totalY - 6}px)`;
    await sleep(105);
    stripEl.style.transition = "transform 70ms ease-in-out";
    stripEl.style.transform = `translateY(-${totalY}px)`;
    await sleep(70);

    return items[selected];
  }

  function showImplCard(machineKey, result) {
    const m = machines[machineKey];
    m.label.textContent = result.label;
    localStorage.setItem(machineKey, result.label);
    m.chips.innerHTML = result.components
      .map(
        (c) => `<span style="
        background: var(--ink); color: var(--bg);
        font-family: 'Space Mono', monospace;
        font-size: 0.55rem; letter-spacing: 0.06em;
        padding: 3px 7px; border-radius: 3px;
      ">${c}</span>`,
      )
      .join("");
    m.text.textContent = result.implementation;
    m.impl.classList.add("visible");
  }

  function updatePips() {
    for (let i = 0; i < MAX_ROLLS; i++) {
      const pip = document.getElementById(`pip-${i}`);
      if (pip) pip.classList.toggle("used", i >= MAX_ROLLS - rollsUsed);
    }
  }

  async function doSpin() {
    console.log("do spin called");
    if (isSpinning || rollsUsed >= MAX_ROLLS) return;
    isSpinning = true;
    rollsUsed++;

    getStartedBtn.hidden = true;
    Object.values(machines).forEach((m) => m.impl.classList.remove("visible"));

    spinBtn.disabled = true;
    spinBtnText.textContent = "SPINNING...";
    updatePips();

    // 1. INPUT
    buildStrip(machines.input.strip, inputs);
    machines.input.el.classList.add("spinning");
    const inputRes = await spinStrip(machines.input.strip, inputs, 2000);
    machines.input.el.classList.remove("spinning");
    machines.input.el.classList.add("landed");
    await sleep(350);
    machines.input.el.classList.remove("landed");
    showImplCard("input", inputRes);
    await sleep(300);

    // 2. OUTPUT
    buildStrip(machines.output.strip, outputs);
    machines.output.el.classList.add("spinning");
    const outputRes = await spinStrip(machines.output.strip, outputs, 2000);
    machines.output.el.classList.remove("spinning");
    machines.output.el.classList.add("landed");
    await sleep(350);
    machines.output.el.classList.remove("landed");
    showImplCard("output", outputRes);
    await sleep(300);

    // 3. CONNECTOR
    buildStrip(machines.connector.strip, connectors);
    machines.connector.el.classList.add("spinning");
    const connectorRes = await spinStrip(
      machines.connector.strip,
      connectors,
      2000,
    );
    machines.connector.el.classList.remove("spinning");
    machines.connector.el.classList.add("landed");
    await sleep(350);
    machines.connector.el.classList.remove("landed");
    showImplCard("connector", connectorRes);
    await sleep(200);

    isSpinning = false;

    if (rollsUsed < MAX_ROLLS) {
      spinBtn.disabled = false;
      spinBtnText.textContent = `REROLL (${MAX_ROLLS - rollsUsed} left)`;
    } else {
      spinBtn.disabled = true;
      spinBtnText.textContent = "NO ROLLS LEFT";
    }

    localStorage.setItem(
      "runtimeChallenge",
      JSON.stringify({
        input: inputRes,
        output: outputRes,
        connector: connectorRes,
      }),
    );

    getStartedBtn.href = "/dashboard";
    getStartedBtn.hidden = false;
    spinBtn.style.marginLeft = "2rem";
    spinBtn.style.marginTop = "0rem";

    document.addEventListener("keydown", (e) => {
      if ((e.key === "A" || e.key === "a")) {
        console.log("a key pressed")
        e.preventDefault();
        window.location.href = "/dashboard";
      }
    });
  }

  function sleep(ms) {
    return new Promise((r) => setTimeout(r, ms));
  }

  updatePips();

  spinBtn.addEventListener("click", doSpin);
  document.addEventListener("keydown", (e) => {
    if ((e.key === " " || e.key === "Enter") && !e.repeat) {
      e.preventDefault();
      doSpin();
    }
  });
</script>
