---
import Layout from "../layouts/Layout.astro";
import params from "../data/parameters.json";

const { inputs, outputs, connectors } = params;
---

<Layout title="Get Your Parameters">
  <main class="generate-page">
    <nav class="nav-bar">
      <a href="/" class="nav-back bebas">← BACK</a>
      <span class="nav-title bebas">RUNTIME</span>
      <div class="rolls-indicator" id="rolls-indicator">
        <span class="rolls-label">ROLLS LEFT:</span>
        <span class="roll-pip" id="pip-0"></span>
        <span class="roll-pip" id="pip-1"></span>
        <span class="roll-pip" id="pip-2"></span>
      </div>
    </nav>

    <section class="machines-section">
      <div class="machines-row">
        <!-- INPUT — Plug -->
        <div class="machine-col">
          <div class="machine" id="machine-input">
            <div class="plug-body machine-body">
              <div class="machine-top-label bebas">INPUT</div>
              <div class="slot-window" id="window-input">
                <div class="slot-strip" id="strip-input"></div>
              </div>
              <div class="plug-dots" aria-hidden="true">
                <span></span><span></span><span></span>
              </div>
            </div>

          </div>
          <div class="machine-label bebas" style="color: var(--yellow)">
            INPUT
          </div>
          <div class="impl-card" id="impl-input">
            <div class="impl-components">
              <span class="impl-tag bebas">COMPONENTS</span>
              <div class="impl-chips" id="chips-input"></div>
            </div>
            <div class="impl-text" id="text-input"></div>
          </div>
        </div>

        <!-- CONNECTOR — Monitor -->
        <div class="machine-col">
          <div class="machine monitor-machine" id="machine-connector">
            <div class="monitor-antennae" aria-hidden="true">
              <div class="antenna left"></div>
              <div class="antenna right"></div>
            </div>
            <div class="monitor-body machine-body">
              <div class="machine-top-label bebas">CONNECTOR</div>
              <div class="monitor-bezel">
                <div class="slot-window dark-window" id="window-connector">
                  <div class="slot-strip" id="strip-connector"></div>
                </div>
                <div class="power-led" aria-hidden="true"></div>
              </div>
            </div>
            <div class="monitor-stand" aria-hidden="true">
              <div class="stand-neck"></div>
              <div class="stand-base"></div>
            </div>
          </div>
          <div class="machine-label bebas" style="color: var(--teal)">
            CONNECTOR
          </div>
          <div class="impl-card" id="impl-connector">
            <div class="impl-components">
              <span class="impl-tag bebas">COMPONENTS</span>
              <div class="impl-chips" id="chips-connector"></div>
            </div>
            <div class="impl-text" id="text-connector"></div>
          </div>
        </div>

        <!-- OUTPUT — Speaker -->
        <div class="machine-col">
          <div class="machine speaker-machine" id="machine-output">
            <div class="speaker-body machine-body">
              <div class="machine-top-label bebas">OUTPUT</div>
              <div class="slot-window" id="window-output">
                <div class="slot-strip" id="strip-output"></div>
              </div>
              <div class="speaker-grille" aria-hidden="true">
                <div class="grille-line"></div>
                <div class="grille-line"></div>
                <div class="grille-line"></div>
                <div class="grille-line"></div>
              </div>
            </div>
          </div>
          <div class="machine-label bebas" style="color: var(--orange)">
            OUTPUT
          </div>
          <div class="impl-card" id="impl-output">
            <div class="impl-components">
              <span class="impl-tag bebas">COMPONENTS</span>
              <div class="impl-chips" id="chips-output"></div>
            </div>
            <div class="impl-text" id="text-output"></div>
          </div>
        </div>
      </div>
    </section>

    <section class="controls-section">
      <button class="spin-btn bebas" id="spin-btn" type="button">
        <span id="spin-btn-text">SPIN!</span>
      </button>
      <div class="controls-spacer"></div>
      <a href="#" class="get-started-btn bebas" id="get-started-btn" hidden>
        GET STARTED →
      </a>
    </section>
  </main>
</Layout>

<style>
  .generate-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
  }

  .nav-bar {
    background: var(--ink);
    color: var(--bg);
    display: flex;
    align-items: center;
    padding: 10px 24px;
    gap: 16px;
    flex-wrap: wrap;
    flex-shrink: 0;
  }
  .nav-back {
    color: var(--yellow);
    text-decoration: none;
    font-size: 1.1rem;
    letter-spacing: 0.06em;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }
  .nav-back:hover {
    opacity: 0.7;
  }
  .nav-title {
    font-size: 1rem;
    letter-spacing: 0.08em;
    flex: 1;
    text-align: center;
  }

  .rolls-indicator {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .rolls-label {
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    color: #888;
    font-family: "Space Mono", monospace;
  }
  .roll-pip {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2.5px solid var(--yellow);
    background: var(--yellow);
    transition:
      background 0.3s,
      border-color 0.3s;
  }
  .roll-pip.used {
    background: transparent;
    border-color: #555;
  }

  .machines-section {
    flex: 1;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    margin-top: 10vh;
    overflow-x: none;
    overflow-y: none;
    min-height: 0;
  }

  .machines-row {
    display: flex;
    align-items: flex-start;
    gap: 10vw;
  }

  .machine-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    width: fit-content
  }

  .machine-label {
    font-size: 1.1rem;
    letter-spacing: 0.1em;
  }

  .machine {
    display: flex;
    align-items: center;
  }
  .machine.spinning .machine-body {
    animation: shake 0.12s ease-in-out infinite;
  }
  .machine.landed .machine-body {
    animation: pop 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .machine-body {
    width: 190px;
    height: 260px;
    border: 4px solid var(--ink);
    border-radius: 14px;
    box-shadow: 7px 7px 0 var(--ink);
    display: flex;
    flex-direction: column;
    align-items: stretch;
    overflow: hidden;
    position: relative;
  }

  .machine-top-label {
    text-align: center;
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    padding: 5px 12px 4px;
    background: rgba(0, 0, 0, 0.14);
    border-bottom: 3px solid var(--ink);
    flex-shrink: 0;
  }

  .slot-window {
    flex: 1;
    overflow: hidden;
    position: relative;
  }
  .dark-window {
    border: 3px solid var(--ink);
    border-radius: 4px;
    background: #0a1628;
  }

  .slot-strip {
    display: flex;
    flex-direction: column;
    transform: translateY(0);
    will-change: transform;
  }

  .plug-body {
    background: var(--yellow);
  }
  .plug-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 8px;
    flex-shrink: 0;
  }
  .plug-dots span {
    width: 7px;
    height: 7px;
    background: var(--ink);
    border-radius: 50%;
    opacity: 0.35;
  }

  .monitor-machine {
    flex-direction: column;
    align-items: center;
  }
  .monitor-antennae {
    display: flex;
    gap: 26px;
    margin-bottom: -3px;
    z-index: 1;
  }
  .antenna {
    width: 7px;
    background: var(--ink);
    border-radius: 4px 4px 0 0;
  }
  .antenna.left {
    height: 38px;
    transform: rotate(-10deg);
    transform-origin: bottom center;
  }
  .antenna.right {
    height: 38px;
    transform: rotate(10deg);
    transform-origin: bottom center;
  }
  .monitor-body {
    background: var(--teal);
    width: 230px;
  }
  .monitor-bezel {
    flex: 1;
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .monitor-bezel .slot-window {
    flex: 1;
  }
  .power-led {
    width: 8px;
    height: 8px;
    background: var(--green);
    border-radius: 50%;
    margin-left: auto;
    box-shadow: 0 0 6px var(--green);
    animation: led-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes led-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.3;
    }
  }
  .monitor-stand {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .stand-neck {
    width: 18px;
    height: 18px;
    background: var(--ink);
  }
  .stand-base {
    width: 72px;
    height: 10px;
    background: var(--ink);
    border-radius: 0 0 4px 4px;
  }

  .speaker-body {
    background: var(--orange);
  }
  .speaker-grille {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 8px 16px;
    flex-shrink: 0;
  }
  .grille-line {
    height: 4px;
    background: rgba(0, 0, 0, 0.2);
    border-radius: 2px;
  }

  .impl-card {
    width: 17rem;
    margin-top: 1rem;
    background: white;
    border: 3px solid var(--ink);
    border-radius: 10px;
    box-shadow: 4px 4px 0 var(--ink);
    padding: 12px 14px;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(16px);
    pointer-events: none;
    transition:
      opacity 0.4s ease,
      transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .impl-card.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .impl-tag {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    opacity: 0.55;
    display: block;
    margin-bottom: 4px;
  }
  .impl-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .impl-text {
    font-size: 0.62rem;
    line-height: 1.65;
    border-top: 2px solid rgba(0, 0, 0, 0.1);
    padding-top: 8px;
    margin-top: 2px;
  }

  .controls-section {
    display: flex;
    align-items: center;
    padding: 16px 32px 24px;
    gap: 16px;
    flex-shrink: 0;
  }
  .controls-spacer {
    flex: 1;
  }

  .spin-btn {
    background: var(--pink);
    color: white;
    border: 4px solid var(--ink);
    border-radius: 8px;
    box-shadow: 6px 6px 0 var(--ink);
    padding: 14px 48px;
    font-size: 2rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition:
      transform 0.1s,
      box-shadow 0.1s,
      background 0.15s;
    user-select: none;
    flex-shrink: 0;
  }
  .spin-btn:hover:not(:disabled) {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0 var(--ink);
    background: #ff1a47;
  }
  .spin-btn:active:not(:disabled) {
    transform: translate(6px, 6px);
    box-shadow: 0 0 0 var(--ink);
  }
  .spin-btn:disabled {
    background: #bbb;
    cursor: not-allowed;
    box-shadow: 3px 3px 0 var(--ink);
    color: #888;
  }

  .get-started-btn {
    background: var(--green);
    color: var(--ink);
    border: 4px solid var(--ink);
    border-radius: 8px;
    box-shadow: 6px 6px 0 var(--ink);
    padding: 14px 28px;
    font-size: 1.5rem;
    letter-spacing: 0.08em;
    text-decoration: none;
    flex-shrink: 0;
    transition:
      transform 0.1s,
      box-shadow 0.1s;
    animation: pop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  .get-started-btn[hidden] {
    display: none !important;
  }
  .get-started-btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0 var(--ink);
  }
  .get-started-btn:active {
    transform: translate(6px, 6px);
    box-shadow: 0 0 0 var(--ink);
  }
</style>

<script define:vars={{ inputs, outputs, connectors }}>
  const ITEM_H = 150;
  const REPEATS = 7;
  const MAX_ROLLS = 3;

  let rollsUsed = 0;
  let isSpinning = false;

  const spinBtn = document.getElementById("spin-btn");
  const spinBtnText = document.getElementById("spin-btn-text");
  const getStartedBtn = document.getElementById("get-started-btn");

  const machines = {
    input: {
      strip: document.getElementById("strip-input"),
      el: document.getElementById("machine-input"),
      impl: document.getElementById("impl-input"),
      chips: document.getElementById("chips-input"),
      text: document.getElementById("text-input"),
      items: inputs,
    },
    output: {
      strip: document.getElementById("strip-output"),
      el: document.getElementById("machine-output"),
      impl: document.getElementById("impl-output"),
      chips: document.getElementById("chips-output"),
      text: document.getElementById("text-output"),
      items: outputs,
    },
    connector: {
      strip: document.getElementById("strip-connector"),
      el: document.getElementById("machine-connector"),
      impl: document.getElementById("impl-connector"),
      chips: document.getElementById("chips-connector"),
      text: document.getElementById("text-connector"),
      items: connectors,
    },
  };

  function buildStrip(stripEl, items) {
    const all = Array.from({ length: REPEATS }, () => items).flat();
    stripEl.innerHTML = all
      .map(
        (item) => `
      <div style="
        height: ${ITEM_H}px;
        display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        gap: 6px; padding: 10px 8px; user-select: none;
      ">
        <div style="
          width: 80px; height: 80px; position: relative;
          display: flex; align-items: center; justify-content: center;
          background: rgba(0,0,0,0.08); border-radius: 8px; overflow: hidden; flex-shrink: 0;
        ">
          <span style="
            font-family: 'Space Mono', monospace; font-size: 0.45rem;
            letter-spacing: 0.06em; text-align: center; opacity: 0.5; position: absolute; padding: 4px;
          ">${item.label}</span>
          <img
            src="${item.image}"
            alt="${item.label}"
            style="position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; padding: 6px;"
            onerror="this.style.display='none'"
          >
        </div>
        <span style="
          font-family: 'Bebas Neue', sans-serif;
          font-size: 1.1rem; letter-spacing: 0.06em; color: white; text-align: center; line-height: 1.1;
        ">${item.label}</span>
      </div>
    `,
      )
      .join("");
    stripEl.style.transition = "none";
    stripEl.style.transform = "translateY(0)";
  }

  async function spinStrip(stripEl, items, duration) {
    const selected = Math.floor(Math.random() * items.length);
    const rotations = 4 + Math.floor(Math.random() * 2);
    const totalY = (rotations * items.length + selected) * ITEM_H;

    stripEl.style.transition = "none";
    stripEl.style.transform = "translateY(0)";
    void stripEl.offsetHeight;

    stripEl.style.transition = `transform ${duration}ms cubic-bezier(0.22, 0.88, 0.26, 1)`;
    stripEl.style.transform = `translateY(-${totalY}px)`;
    await sleep(duration);

    stripEl.style.transition = "transform 80ms ease-out";
    stripEl.style.transform = `translateY(-${totalY + 12}px)`;
    await sleep(85);
    stripEl.style.transition = "transform 100ms ease-out";
    stripEl.style.transform = `translateY(-${totalY - 6}px)`;
    await sleep(105);
    stripEl.style.transition = "transform 70ms ease-in-out";
    stripEl.style.transform = `translateY(-${totalY}px)`;
    await sleep(70);

    return items[selected];
  }

  function showImplCard(machineKey, result) {
    const m = machines[machineKey];
    m.chips.innerHTML = result.components
      .map(
        (c) => `<span style="
        background: var(--ink); color: var(--bg);
        font-family: 'Space Mono', monospace;
        font-size: 0.55rem; letter-spacing: 0.06em;
        padding: 3px 7px; border-radius: 3px;
      ">${c}</span>`,
      )
      .join("");
    m.text.textContent = result.implementation;
    m.impl.classList.add("visible");
  }

  function updatePips() {
    for (let i = 0; i < MAX_ROLLS; i++) {
      const pip = document.getElementById(`pip-${i}`);
      if (pip) pip.classList.toggle("used", i >= MAX_ROLLS - rollsUsed);
    }
  }

  async function doSpin() {
    if (isSpinning || rollsUsed >= MAX_ROLLS) return;
    isSpinning = true;
    rollsUsed++;

    getStartedBtn.hidden = true;
    Object.values(machines).forEach((m) => m.impl.classList.remove("visible"));

    spinBtn.disabled = true;
    spinBtnText.textContent = "SPINNING...";
    updatePips();

    // 1. INPUT
    machines.input.el.classList.add("spinning");
    const inputRes = await spinStrip(machines.input.strip, inputs, 2000);
    machines.input.el.classList.remove("spinning");
    machines.input.el.classList.add("landed");
    await sleep(350);
    machines.input.el.classList.remove("landed");
    showImplCard("input", inputRes);
    await sleep(300);

    // 2. OUTPUT
    machines.output.el.classList.add("spinning");
    const outputRes = await spinStrip(machines.output.strip, outputs, 2000);
    machines.output.el.classList.remove("spinning");
    machines.output.el.classList.add("landed");
    await sleep(350);
    machines.output.el.classList.remove("landed");
    showImplCard("output", outputRes);
    await sleep(300);

    // 3. CONNECTOR
    machines.connector.el.classList.add("spinning");
    const connectorRes = await spinStrip(
      machines.connector.strip,
      connectors,
      2000,
    );
    machines.connector.el.classList.remove("spinning");
    machines.connector.el.classList.add("landed");
    await sleep(350);
    machines.connector.el.classList.remove("landed");
    showImplCard("connector", connectorRes);
    await sleep(200);

    isSpinning = false;

    if (rollsUsed < MAX_ROLLS) {
      spinBtn.disabled = false;
      spinBtnText.textContent = `REROLL (${MAX_ROLLS - rollsUsed} left)`;
    } else {
      spinBtn.disabled = true;
      spinBtnText.textContent = "NO ROLLS LEFT";
    }

    getStartedBtn.hidden = false;
  }

  function sleep(ms) {
    return new Promise((r) => setTimeout(r, ms));
  }

  buildStrip(machines.input.strip, inputs);
  buildStrip(machines.output.strip, outputs);
  buildStrip(machines.connector.strip, connectors);

  updatePips();

  spinBtn.addEventListener("click", doSpin);
  document.addEventListener("keydown", (e) => {
    if ((e.key === " " || e.key === "Enter") && !e.repeat) {
      e.preventDefault();
      doSpin();
    }
  });
</script>
