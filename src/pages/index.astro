---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout title="Runtime">
  <div class="corner tl"></div>
  <div class="corner tr"></div>
  <div class="w-full flex flex-col items-center justify-center gap-[4rem]">
    <div class="flex flex-col mt-[4rem] items-center justify-center">
      <img
        src="./logo.png"
        class="p-[2rem] border-4 w-1/2"
        style="border-radius: 20px;"
      />

      <div class="stripe mt-[4rem]" style="background: var(--pink)"></div>
      <div class="stripe" style="background: var(--orange)"></div>
      <div class="stripe" style="background: var(--yellow)"></div>
    </div>

    <div class="flex justify-center mr-[2rem] ml-[2rem] w-[80%]">
      <img src="./steps.png" class="w-full" />
    </div>
  </div>

  <div class="cta-div mt-[6rem] mb-[2rem] items-center justify-center">
    <a href="/generate" class="cool-btn items-center justify-center">
      <span class="cta-text blink">PRESS ANY KEY TO START</span>
    </a>
  </div>

  <section class="faq-section">
    <h2 class="faq-title bebas">FAQ</h2>
    <div class="faq-grid">
      <div class="faq-col">
        <details class="faq-item">
          <summary class="faq-summary">
            <span class="faq-q bebas">WHAT IS RUNTIME?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p class="faq-body">
            Runtime is a PCB design challenge where you're randomly assigned
            hardware parameters — an input sensor, output device, and connector
            type — then build a working circuit board around them.
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-summary">
            <span class="faq-q bebas">HOW DOES SPINNING WORK?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p class="faq-body">
            Click SPIN! to randomly assign your three parameters. Each spin is
            fully random. If you don't like the result, use a reroll. When
            you're satisfied, click GET STARTED to lock in your challenge.
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-summary">
            <span class="faq-q bebas">HOW MANY SPINS DO I GET?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p class="faq-body">
            3 spins per session. Each reroll completely replaces your previous
            parameters. Once you hit GET STARTED, your current roll is locked in
            as your official challenge.
          </p>
        </details>
      </div>

      <div class="faq-col">
        <details class="faq-item">
          <summary class="faq-summary">
            <span class="faq-q bebas">WHAT HARDWARE DO I NEED?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p class="faq-body">
            A microcontroller (Arduino, RP2040, or similar), the components
            listed on your parameter cards, a soldering iron, and PCB design
            software. Prototyping on a breadboard first is strongly recommended.
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-summary">
            <span class="faq-q bebas">WHAT ARE THE INPUT OPTIONS?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p class="faq-body">
            Eight sensors: humidity, temperature, light level, motion (PIR),
            sound level, barometric pressure, proximity, and magnetic field.
            Each card includes recommended components and wiring notes.
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-summary">
            <span class="faq-q bebas">WHAT ARE THE OUTPUT OPTIONS?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p class="faq-body">
            Eight devices: LED array, buzzer, binary LED display, Morse code
            blinker, LCD screen, servo motor, RGB LED matrix, and 7-segment
            display. The dashboard shows implementation details for whichever
            you roll.
          </p>
        </details>
      </div>

      <div class="faq-col">
        <details class="faq-item">
          <summary class="faq-summary">
            <span class="faq-q bebas">WHAT CONNECTOR TYPES ARE THERE?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p class="faq-body">
            Eight form factors: keychain, freeform shape cutout, big arcade
            button, USB-C power delivery, badge clip, fridge magnet, rotary
            encoder knob, and card swipe strip.
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-summary">
            <span class="faq-q bebas">HOW LONG DOES A BUILD TAKE?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p class="faq-body">
            Design and fabrication typically takes 2–6 hours depending on
            complexity and experience level. Most people prototype on a
            breadboard first, then commit to a PCB layout once the circuit is
            confirmed working.
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-summary">
            <span class="faq-q bebas">DO I NEED PCB EXPERIENCE?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p class="faq-body">
            Not at all. Runtime is designed as a first PCB challenge. Each
            parameter card includes component suggestions and wiring guidance to
            get you started — that's kind of the whole point.
          </p>
        </details>
      </div>
    </div>
  </section>
</Layout>

<style>
  :global(html) {
    height: 100%;
    overflow-x: hidden;
  }
  :global(body) {
    min-height: 100%;
    overflow-x: hidden;
  }
  .top-banner {
    flex-shrink: 0;
    background: var(--ink);
    color: var(--yellow);
    text-align: center;
    padding: 7px 16px;
    font-size: 0.65rem;
    letter-spacing: 0.28em;
    font-weight: 700;
  }

  .hero {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 20px 24px;
    position: relative;
    overflow: hidden;
    text-align: center;
    min-height: 0;
  }

  .corner {
    position: absolute;
    width: 24px;
    height: 24px;
    border-color: var(--ink);
    border-style: solid;
    opacity: 0.5;
  }
  .corner.tl {
    top: 16px;
    left: 16px;
    border-width: 3px 0 0 3px;
  }
  .corner.tr {
    top: 16px;
    right: 16px;
    border-width: 3px 3px 0 0;
  }

  .main-title {
    font-family: "Helvetica", sans-serif;
    font-size: clamp(60px, 14dvw, 120px);
    color: var(--bg);
    -webkit-text-stroke: 6px var(--ink);
    text-shadow: 8px 8px 0 var(--ink);
    line-height: 0.88;
    letter-spacing: 0.02em;
    user-select: none;
  }

  .subtitle {
    font-size: clamp(0.55rem, 1.4dvw, 0.75rem);
    letter-spacing: 0.22em;
    font-weight: 700;
    opacity: 0.65;
    text-transform: uppercase;
    margin-top: -2px;
  }

  .stripe {
    height: 16px;
    width: 100%;
  }

  .cta-div {
    flex-shrink: 0;
    padding: 14px 24px 18px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cta-text {
    font-family: "Bebas Neue", sans-serif;
    font-size: 2rem;
    letter-spacing: 0.1em;
  }

  .blink {
    animation: blink 1.1s step-end infinite;
  }

  /* ── FAQ ── */
  .faq-section {
    background: var(--ink);
    padding: 4rem 2.5rem 5rem;
  }

  .faq-title {
    text-align: center;
    font-size: clamp(2rem, 5dvw, 3.5rem);
    letter-spacing: 0.12em;
    color: var(--yellow);
    margin: 0 0 2.5rem;
  }

  .faq-grid {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    max-width: 1100px;
    margin: 0 auto;
  }

  .faq-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-item {
    background: var(--bg);
    border: 3px solid var(--bg);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 4px 4px 0 rgba(255, 255, 255, 0.15);
  }

  .faq-item[open] {
    box-shadow: 4px 4px 0 var(--yellow);
  }

  .faq-summary {
    list-style: none;
    cursor: pointer;
    padding: 12px 14px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    user-select: none;
  }

  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-summary:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .faq-q {
    font-size: 1rem;
    letter-spacing: 0.06em;
    color: var(--ink);
    line-height: 1.1;
  }

  .faq-icon {
    width: 20px;
    height: 20px;
    border: 2.5px solid var(--ink);
    border-radius: 50%;
    flex-shrink: 0;
    position: relative;
  }

  .faq-icon::before,
  .faq-icon::after {
    content: "";
    position: absolute;
    background: var(--ink);
    border-radius: 1px;
    transition:
      opacity 0.2s,
      transform 0.2s;
  }

  .faq-icon::before {
    width: 10px;
    height: 2px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .faq-icon::after {
    width: 2px;
    height: 10px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .faq-item[open] .faq-icon {
    border-color: var(--ink);
    transform: rotate(45deg);
  }

  .faq-body {
    font-size: 0.62rem;
    line-height: 1.75;
    padding: 0 14px 14px;
    color: var(--ink);
    border-top: 2px solid rgba(0, 0, 0, 0.1);
    padding-top: 10px;
    margin: 0;
    transform-origin: top center;
  }

  .cool-btn {
    background: var(--pink);
    margin-bottom: 2rem;
    margin-top: -5rem;
    height: min-content;
    color: white;
    border: 4px solid var(--ink);
    border-radius: 8px;
    box-shadow: 6px 6px 0 var(--ink);
    padding: 14px 48px;
    font-size: 2rem;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition:
      transform 0.1s,
      box-shadow 0.1s,
      background 0.15s;
    user-select: none;
    flex-shrink: 0;
  }

  .cool-btn:hover:not(:disabled) {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0 var(--ink);
    background: #ff1a47;
  }

  .cool-btn:active:not(:disabled) {
    transform: translate(6px, 6px);
    box-shadow: 0 0 0 var(--ink);
  }

  .cool-btn:disabled {
    background: #bbb;
    cursor: not-allowed;
    box-shadow: 3px 3px 0 var(--ink);
    color: #888;
  }

  @keyframes faq-body-open {
    0% {
      opacity: 0;
      transform: scaleY(0.4) translateY(-6px);
    }
    55% {
      transform: scaleY(1.06) translateY(0);
    }
    75% {
      transform: scaleY(0.97);
    }
    100% {
      opacity: 1;
      transform: scaleY(1) translateY(0);
    }
  }

  @keyframes faq-card-pop {
    0% {
      transform: scale(1);
    }
    45% {
      transform: scale(1.03);
    }
    70% {
      transform: scale(0.985);
    }
    100% {
      transform: scale(1);
    }
  }

  @media (max-width: 700px) {
    .faq-grid {
      flex-direction: column;
    }
  }
</style>

<script>
  const go = () => {
    window.location.href = "/generate";
  };

  document.addEventListener("keydown", (e) => {
    if (window.scrollY > 80) return;
    if (
      !["Tab", "Escape", "F1", "F5", "F11", "F12", "Alt", "Control"].includes(
        e.key,
      )
    )
      go();
  });

  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest("a") && !target.closest(".faq-section")) go();
  });

  // Accordion: only one item open at a time
  const faqItems = document.querySelectorAll<HTMLDetailsElement>(".faq-item");
  faqItems.forEach((item) => {
    item.addEventListener("toggle", () => {
      if (item.open) {
        faqItems.forEach((other) => {
          if (other !== item) other.open = false;
        });
      }
    });
  });
</script>
