---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import FuzzyText from "../components/FuzzyText";
---

<Layout title="Runtime">
  <img src="./hc-flag.png" class="absolute w-[10vw] left-[1rem] top-[1rem]" />

  <div class="cta-div fixed w-fit right-[1rem] top-[1rem] ">
    <a href="/dashboard" class="hidden cool-btn h-min p-[1rem]" id="dashboard-btn">
      <span class="cta-text text-[1.5rem]">RETURN TO DASHBOARD</span>
    </a>
  </div>

  <div class="w-full flex flex-col items-center justify-center gap-[4rem]">
    <div class="flex flex-col mt-[2rem] items-center justify-center">
      <img
        src="./logo.png"
        class="p-[2rem] border-4 w-1/2"
        style="border-radius: 20px;"
      />

      <div class="w-min flex flex-col gap-[1.5rem]" style="margin-top: calc(10vh - 1rem)">
        <FuzzyText
          text="spend 5 hours making a printed circuit board"
          client:idle
          baseIntensity={0.05}
          hoverIntensity={0.15}
          color="#000000"
          fontSize="2rem"
          clickEffect="true"
          className="w-fit"
        />
        <FuzzyText
          text="we'll send you $20 to build it"
          client:idle
          baseIntensity={0.05}
          hoverIntensity={0.15}
          color="#000000"
          fontSize="2rem"
          clickEffect="true"
          className="w-fit"
        />
      </div>
      <p class="text-[13px] mt-[1rem]">no experience required. teens 13-18 only.</p>

      <div class="stripe mt-[4rem]" style="background: var(--pink)"></div>
      <div class="stripe" style="background: var(--orange)"></div>
      <div class="stripe" style="background: var(--yellow)"></div>
    </div>

    <div
      class="flex flex-col justify-center items-center gap-[2rem] mr-[2rem] ml-[2rem] w-[80%]"
    >
      <FuzzyText
          text="How does it work?"
          client:idle
          baseIntensity={0.05}
          hoverIntensity={0.1}
          color="#000000"
          fontSize="2.5rem"
          clickEffect="true"
        />
      <img src="./steps.png" class="w-full" />
    </div>
  </div>

  <div class="cta-div mt-[6rem] mb-[2rem] items-center justify-center">
    <a href="/generate" class="cool-btn items-center justify-center p-[1rem] pl-[2rem] pr-[2rem]">
      <span class="cta-text text-[2rem] blink">START NOW</span>
    </a>
  </div>

  <section class="faq-section">
    <h2 class="faq-title bebas">Frequently Asked Questions</h2>
    <div class="faq-grid">
      <div class="faq-col">
        <details class="faq-item">
          <summary class="faq-summary">
            <span class="faq-q bebas">WHAT IS RUNTIME?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p class="faq-body">
            Runtime is Hack Club program where teens can learn how to make a PCB
            and get the money to build it! You'll spin for an input, output, and
            connector and you're tasked with making a PCB that uses those 3
            parameters.
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-summary">
            <span class="faq-q bebas">WHO CAN PARTICIPATE?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p class="faq-body">
            Anyone 13-18! No hardware experience required, we have guides to
            teach you!
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-summary">
            <span class="faq-q bebas">WHAT IS HACK CLUB?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p class="faq-body">
            Hack Club is a non-profit organization and a community of 100k+
            teenage makers. We run events online and in-person that reward
            people making open source projects. Thanks to our donors we are
            always running crazy events at no cost for teens. Previously we ran;
          </p>
        </details>
      </div>

      <div class="faq-col">
        <details class="faq-item">
          <summary class="faq-summary">
            <span class="faq-q bebas">IS THIS FREE?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p class="faq-body">
            Yep! Hack Club programs are free to participate in. For Runtime, all
            you have to do is spend 5 hours designing your PCB and we'll send
            you a $20 grant to manufacture your board!
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-summary">
            <span class="faq-q bebas">I DON'T KNOW HARDWARE</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p class="faq-body">
            That's okay! We have guides made for beginners, and there are
            thousands of teenagers just like you who are learning right along
            side you on the Hack Club Slack. Runtime is made for beginners, and
            we want more teens building hardware!
          </p>
        </details>

        <details class="faq-item">
          <summary class="faq-summary">
            <span class="faq-q bebas">WHAT DO I SUBMIT?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </summary>
          <p class="faq-body">
            All your design and production files should be in a GitHub repo,
            along with your firmware. Your journals should also be in your repo
            (written in markdown).
          </p>
        </details>
      </div>
    </div>
  </section>
</Layout>

<style>
  :global(html) {
    height: 100%;
    overflow-x: hidden;
  }
  :global(body) {
    min-height: 100%;
    overflow-x: hidden;
  }
  .top-banner {
    flex-shrink: 0;
    background: var(--ink);
    color: var(--yellow);
    text-align: center;
    padding: 7px 16px;
    font-size: 0.65rem;
    letter-spacing: 0.28em;
    font-weight: 700;
  }

  .hero {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 20px 24px;
    position: relative;
    overflow: hidden;
    text-align: center;
    min-height: 0;
  }

  .corner {
    position: absolute;
    width: 24px;
    height: 24px;
    border-color: var(--ink);
    border-style: solid;
    opacity: 0.5;
  }
  .corner.tl {
    top: 16px;
    left: 16px;
    border-width: 3px 0 0 3px;
  }
  .corner.tr {
    top: 16px;
    right: 16px;
    border-width: 3px 3px 0 0;
  }

  .main-title {
    font-family: "Helvetica", sans-serif;
    font-size: clamp(60px, 14dvw, 120px);
    color: var(--bg);
    -webkit-text-stroke: 6px var(--ink);
    text-shadow: 8px 8px 0 var(--ink);
    line-height: 0.88;
    letter-spacing: 0.02em;
    user-select: none;
  }

  .subtitle {
    font-size: clamp(0.55rem, 1.4dvw, 0.75rem);
    letter-spacing: 0.22em;
    font-weight: 700;
    opacity: 0.65;
    text-transform: uppercase;
    margin-top: -2px;
  }

  .stripe {
    height: 16px;
    width: 100%;
  }

  .cta-div {
    flex-shrink: 0;
    padding: 14px 24px 18px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cta-text {
    font-family: "Bebas Neue", sans-serif;
    letter-spacing: 0.1em;
  }

  .blink {
    animation: blink 1.1s step-end infinite;
  }

  /* ── FAQ ── */
  .faq-section {
    background: var(--ink);
    padding: 4rem 2.5rem 5rem;
  }

  .faq-title {
    text-align: center;
    font-size: clamp(2rem, 5dvw, 3.5rem);
    letter-spacing: 0.12em;
    color: var(--yellow);
    margin: 0 0 2.5rem;
  }

  .faq-grid {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    max-width: 1100px;
    margin: 0 auto;
  }

  .faq-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-item {
    background: var(--bg);
    border: 3px solid var(--bg);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 4px 4px 0 rgba(255, 255, 255, 0.15);
  }

  .faq-item[open] {
    box-shadow: 4px 4px 0 var(--yellow);
  }

  .faq-summary {
    list-style: none;
    cursor: pointer;
    padding: 12px 14px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    user-select: none;
  }

  .faq-summary::-webkit-details-marker {
    display: none;
  }

  .faq-summary:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .faq-q {
    font-size: 1rem;
    letter-spacing: 0.06em;
    color: var(--ink);
    line-height: 1.1;
  }

  .faq-icon {
    width: 20px;
    height: 20px;
    border: 2.5px solid var(--ink);
    border-radius: 50%;
    flex-shrink: 0;
    position: relative;
  }

  .faq-icon::before,
  .faq-icon::after {
    content: "";
    position: absolute;
    background: var(--ink);
    border-radius: 1px;
    transition:
      opacity 0.2s,
      transform 0.2s;
  }

  .faq-icon::before {
    width: 10px;
    height: 2px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .faq-icon::after {
    width: 2px;
    height: 10px;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .faq-item[open] .faq-icon {
    border-color: var(--ink);
    transform: rotate(45deg);
  }

  .faq-body {
    font-size: 0.62rem;
    line-height: 1.75;
    padding: 0 14px 14px;
    color: var(--ink);
    border-top: 2px solid rgba(0, 0, 0, 0.1);
    padding-top: 10px;
    margin: 0;
    transform-origin: top center;
  }

  .cool-btn {
    background: var(--pink);
    color: white;
    border: 4px solid var(--ink);
    border-radius: 8px;
    box-shadow: 6px 6px 0 var(--ink);
    transition:
      transform 0.1s,
      box-shadow 0.1s,
      background 0.15s;
  }

  .cool-btn:hover:not(:disabled) {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0 var(--ink);
    background: #ff1a47;
  }

  .cool-btn:active:not(:disabled) {
    transform: translate(6px, 6px);
    box-shadow: 0 0 0 var(--ink);
  }

  .cool-btn:disabled {
    background: #bbb;
    cursor: not-allowed;
    box-shadow: 3px 3px 0 var(--ink);
    color: #888;
  }

  @keyframes faq-body-open {
    0% {
      opacity: 0;
      transform: scaleY(0.4) translateY(-6px);
    }
    55% {
      transform: scaleY(1.06) translateY(0);
    }
    75% {
      transform: scaleY(0.97);
    }
    100% {
      opacity: 1;
      transform: scaleY(1) translateY(0);
    }
  }

  @keyframes faq-card-pop {
    0% {
      transform: scale(1);
    }
    45% {
      transform: scale(1.03);
    }
    70% {
      transform: scale(0.985);
    }
    100% {
      transform: scale(1);
    }
  }

  @media (max-width: 700px) {
    .faq-grid {
      flex-direction: column;
    }
  }
</style>

<script>
  // Accordion: only one item open at a time
  const faqItems = document.querySelectorAll<HTMLDetailsElement>(".faq-item");
  faqItems.forEach((item) => {
    item.addEventListener("toggle", () => {
      if (item.open) {
        faqItems.forEach((other) => {
          if (other !== item) other.open = false;
        });
      }
    });
  });

  if(localStorage.getItem("input")) {
    document.getElementById("dashboard-btn")?.classList.remove("hidden");
  }
</script>
